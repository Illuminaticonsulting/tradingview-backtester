# TradingView AI Backtester - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# DATABASE (Docker Compose)
# ============================================
POSTGRES_USER=backtester
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=backtester

# ============================================
# API SECURITY (required)
# ============================================
# Generate with: openssl rand -hex 32
BACKTESTER_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BACKTESTER_ENCRYPTION_KEY=CHANGE_ME_GENERATE_FERNET_KEY
BACKTESTER_DEBUG=false

# ============================================
# AI PROVIDER API KEYS (required - choose one)
# ============================================

# Anthropic Claude API Key
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek API Key
# Get from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-...

# ============================================
# TRADINGVIEW CREDENTIALS (optional)
# ============================================

# Only needed if you want to save charts or access premium features
TRADINGVIEW_USERNAME=
TRADINGVIEW_PASSWORD=

# ============================================
# PRODUCTION (Docker)
# ============================================
BACKTESTER_DATABASE_URL=postgresql+asyncpg://backtester:CHANGE_ME@postgres:5432/backtester
BACKTESTER_REDIS_URL=redis://redis:6379/0
NEXT_PUBLIC_API_URL=http://localhost:8000
DOMAIN=backtester.yourdomain.com
